---
import DevLayout from '../layouts/DevLayout.astro';

const packages = [
  { name: '@autional/core', desc: 'Token management, API client, auth flows', install: 'npm install @autional/core' },
  { name: '@autional/react', desc: 'React SDK — AuthProvider, useAuth, RequireAuth', install: 'npm install @autional/react @autional/core' },
  { name: '@autional/vue', desc: 'Vue 3 SDK — plugin, composables, guards', install: 'npm install @autional/vue @autional/core' },
  { name: '@autional/next', desc: 'Next.js App Router SDK', install: 'npm install @autional/next @autional/core' },
  { name: '@autional/node', desc: 'Node.js server middleware', install: 'npm install @autional/node' },
  { name: '@autional/miniapp', desc: 'WeChat Mini Program adapter', install: 'npm install @autional/miniapp @autional/core' },
  { name: '@autional/react-native', desc: 'React Native SDK', install: 'npm install @autional/react-native @autional/core' },
  { name: '@autional/plugin-mfa', desc: 'MFA setup flows', install: 'npm install @autional/plugin-mfa' },
  { name: '@autional/plugin-passkey', desc: 'Passkey registration and assertion', install: 'npm install @autional/plugin-passkey' },
  { name: '@autional/plugin-tenant', desc: 'Multi-tenant organization management', install: 'npm install @autional/plugin-tenant' },
];
const apis = [
  'api-identity','api-mfa','api-oauth','api-session','api-profile','api-tenant','api-rbac',
  'api-billing','api-audit','api-compliance','api-wallet','api-point','api-pay','api-storage',
  'api-notification','api-communication','api-secret','api-status','api-saml','api-verification',
];

const highlights = [
  { label: 'Packages', value: '31' },
  { label: 'API Clients', value: '20+' },
  { label: 'Microservices', value: '24' },
];
---
<DevLayout title="SDK — Autional Developers" description="Autional SDK — 31 packages, 20+ API clients for React, Vue, Next.js, Node.js. Ship identity faster with type-safe, production-ready libraries.">
  <section class="grid gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
    <div>
      <span class="brand-kicker">Developer Platform</span>
      <h1 class="mt-6 max-w-3xl text-5xl font-extrabold leading-[1.05] tracking-[-0.06em] text-primary-900 sm:text-6xl">
        Ship identity faster with production-ready SDKs and API clients.
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-neutral-600">
        Autional gives your team a unified package surface for authentication, MFA, tenants, passkeys, sessions, and policy-heavy enterprise flows without stitching together multiple vendors.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/quickstart" class="brand-button-primary">Start In 3 Steps</a>
        <a href="/api" class="brand-button-secondary">Browse API Reference</a>
      </div>
      <div class="mt-10 grid max-w-2xl gap-4 sm:grid-cols-3">
        {highlights.map((item) => (
          <div class="brand-card px-5 py-5">
            <div class="text-2xl font-extrabold tracking-[-0.05em] text-primary-800">{item.value}</div>
            <div class="mt-2 text-sm text-neutral-500">{item.label}</div>
          </div>
        ))}
      </div>
    </div>

    <div class="developer-panel brand-grid relative overflow-hidden px-6 py-7">
      <div class="absolute -right-10 -top-10 h-40 w-40 rounded-full bg-sky-300/10 blur-3xl"></div>
      <div class="relative flex items-center justify-between text-xs uppercase tracking-[0.28em] text-slate-400">
        <span>Quick Install</span>
        <span>React / Vue / Next</span>
      </div>
      <pre class="developer-code mt-5">
<span class="text-slate-500">$</span> <span class="text-amber-300">npm</span> <span class="text-slate-100">install</span> <span class="text-sky-300">@autional/react</span> <span class="text-sky-300">@autional/core</span>

<span class="text-violet-300">import</span> <span class="text-slate-100">&#123; AuthProvider &#125;</span> <span class="text-violet-300">from</span> <span class="text-emerald-300">'@autional/react'</span>;

<span class="text-violet-300">export function</span> <span class="text-amber-300">App</span><span class="text-slate-200">()</span> <span class="text-slate-200">&#123;</span>
  <span class="text-violet-300">return</span> <span class="text-slate-200">(</span>
    <span class="text-sky-300">&lt;AuthProvider</span> <span class="text-amber-200">tenant</span><span class="text-slate-200">=</span><span class="text-emerald-300">"demo"</span> <span class="text-sky-300">/&gt;</span>
  <span class="text-slate-200">)</span>;
<span class="text-slate-200">&#125;</span>
      </pre>
      <div class="mt-6 flex flex-wrap gap-2">
        <span class="developer-chip">Enterprise SSO</span>
        <span class="developer-chip">Passkey</span>
        <span class="developer-chip">RBAC</span>
        <span class="developer-chip">Tenant Isolation</span>
      </div>
    </div>
  </section>

  <section class="mt-16">
    <div class="flex items-end justify-between gap-4">
      <div>
        <span class="brand-kicker">Framework SDKs</span>
        <h2 class="mt-4 text-3xl font-bold tracking-[-0.04em] text-primary-900">Pick the package that matches your runtime.</h2>
      </div>
      <a href="/migration" class="hidden text-sm font-semibold text-primary-700 md:inline-flex">View migration guides</a>
    </div>
    <div class="mt-8 grid gap-4">
      {packages.map((p) => (
        <div class="brand-card flex flex-col gap-4 px-6 py-5 lg:flex-row lg:items-center lg:justify-between">
          <div>
            <code class="text-sm font-semibold text-primary-700">{p.name}</code>
            <p class="mt-2 text-sm leading-7 text-neutral-600">{p.desc}</p>
          </div>
          <code class="inline-flex max-w-full overflow-x-auto rounded-2xl bg-slate-950 px-4 py-3 text-xs leading-6 text-slate-100 lg:max-w-[28rem]">{p.install}</code>
        </div>
      ))}
    </div>
  </section>

  <section class="mt-16 grid gap-10 lg:grid-cols-[0.78fr_1.22fr]">
    <div class="brand-card px-6 py-7">
      <span class="brand-kicker">Usage Model</span>
      <h2 class="mt-4 text-3xl font-bold tracking-[-0.04em] text-primary-900">One package surface, many deployment paths.</h2>
      <p class="mt-4 text-sm leading-7 text-neutral-600">
        Install a framework package for UI integration, pair it with generated API clients when you need deeper control, and keep migration guides nearby when moving from an existing auth provider.
      </p>
      <div class="mt-6 space-y-3 text-sm text-neutral-600">
        <div class="rounded-2xl border border-primary-100 bg-primary-50/80 px-4 py-3">
          <strong class="text-primary-800">Fast start:</strong> add a package and wrap your app.
        </div>
        <div class="rounded-2xl border border-sky-100 bg-sky-50/80 px-4 py-3">
          <strong class="text-primary-800">Deep integration:</strong> call generated clients and gateway docs.
        </div>
        <div class="rounded-2xl border border-amber-100 bg-amber-50/80 px-4 py-3">
          <strong class="text-primary-800">Enterprise rollout:</strong> use migration playbooks and tenant-aware setup.
        </div>
      </div>
    </div>

    <div class="brand-card px-6 py-7">
      <div class="flex items-center justify-between gap-4">
        <div>
          <span class="brand-kicker">Generated Clients</span>
          <h2 class="mt-4 text-3xl font-bold tracking-[-0.04em] text-primary-900">Bring every service into the same developer workflow.</h2>
        </div>
        <span class="hidden rounded-full bg-primary-50 px-4 py-2 text-xs font-semibold uppercase tracking-[0.24em] text-primary-700 md:inline-flex">OpenAPI synced</span>
      </div>
      <div class="mt-8 grid gap-3 sm:grid-cols-2 xl:grid-cols-3">
        {apis.map((a) => (
          <div class="rounded-2xl border border-primary-100/80 bg-white px-4 py-4 shadow-soft">
            <code class="text-xs text-primary-700">@autional/{a}</code>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="mt-16 brand-shell px-6 py-10 text-center sm:px-10">
    <span class="brand-kicker">Ready To Ship</span>
    <h2 class="mt-5 text-3xl font-bold tracking-[-0.04em] text-primary-900 sm:text-4xl">Install once. Keep auth coherent across app, API, and tenant boundaries.</h2>
    <p class="mx-auto mt-4 max-w-2xl text-base leading-8 text-neutral-600">
      Start with the framework SDK, reach for the generated clients when you need service-level control, and keep the migration guide nearby for enterprise cutover work.
    </p>
    <pre class="developer-code mx-auto mt-6 max-w-xl text-left"><span class="text-slate-500">$</span> <span class="text-amber-300">npm</span> <span class="text-slate-100">install</span> <span class="text-sky-300">@autional/react</span> <span class="text-sky-300">@autional/core</span></pre>
  </section>
</DevLayout>
