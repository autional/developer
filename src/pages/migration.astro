---
import DevLayout from '../layouts/DevLayout.astro';
const steps = [
  { from: 'Auth0', steps: ['Create Autional tenant → configure Auth0 as IdP', 'Export Auth0 rules → migrate to Autional Actions', 'Update SDK from auth0-js to @autional/core', 'Verify token validation with Autional JWKS endpoint'], time: '1-2 days' },
  { from: 'Clerk', steps: ['Export users via Clerk API → import to Autional tenant', 'Replace Clerk components with @autional/react components', 'Update webhook endpoints to Autional event format', 'Verify SSO + MFA configuration on Autional Admin Console'], time: '2-3 days' },
  { from: 'Firebase Auth', steps: ['Export users from Firebase → import via Autional Admin API', 'Replace Firebase SDK with @autional/react', 'Migrate custom claims to Autional RBAC roles', 'Reconfigure social login providers in Autional'], time: '3-5 days' },
  { from: 'Keycloak', steps: ['Export Keycloak realm → Autional tenant config', 'Synchronize users via SCIM 2.0 protocol', 'Map Keycloak roles to Autional RBAC', 'Update application SDK to @autional/\*'], time: '3-5 days' },
];
---
<DevLayout title="Migration Guide — Autional Developers" description="Migrate from Auth0, Clerk, Firebase Auth, or Keycloak to Autional. Cut-over playbooks with step-by-step instructions.">
  <section class="text-center">
    <span class="brand-kicker">Migration Guides</span>
    <h1 class="mt-6 text-5xl font-extrabold tracking-[-0.06em] text-primary-900 sm:text-6xl">Cut over from your current auth stack without losing control.</h1>
    <p class="mx-auto mt-6 max-w-3xl text-lg leading-8 text-neutral-600">
      These playbooks focus on practical migration work: tenant setup, user export and import, SDK replacement, policy mapping, and final verification.
    </p>
  </section>

  <section class="mt-14 space-y-6">
    {steps.map((s) => (
      <div class="brand-card px-6 py-6">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
          <h2 class="text-2xl font-bold tracking-[-0.03em] text-primary-900">From {s.from}</h2>
          <span class="inline-flex rounded-full bg-primary-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.24em] text-primary-700">Est. {s.time}</span>
        </div>
        <ol class="mt-6 space-y-3">
          {s.steps.map((step, i) => (
            <li class="flex items-start gap-3 text-sm leading-7 text-neutral-600">
              <span class="mt-0.5 flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-primary-700 text-xs font-bold text-white">{i + 1}</span>
              <span>{step}</span>
            </li>
          ))}
        </ol>
      </div>
    ))}
  </section>
</DevLayout>
